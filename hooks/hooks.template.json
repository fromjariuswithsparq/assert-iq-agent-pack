{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "bash --noprofile --norc -c 'R=\"${CLAUDE_PLUGIN_ROOT:-__PACK_ROOT__}\"; S=\"$R/hooks/scripts/skill-improve-session-start.sh\"; [ -f \"$S\" ] || exit 0; chmod +x \"$S\" && \"$S\"'",
        "osx": "bash --noprofile --norc -c 'R=\"${CLAUDE_PLUGIN_ROOT:-__PACK_ROOT__}\"; S=\"$R/hooks/scripts/skill-improve-session-start.sh\"; [ -f \"$S\" ] || exit 0; chmod +x \"$S\" && \"$S\"'",
