        "windows": "powershell -NoProfile -ExecutionPolicy Bypass -File \"__PACK_ROOT__\\hooks\\scripts\\skill-improve-session-start.ps1\""
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "bash --noprofile --norc -c 'R=\"${CLAUDE_PLUGIN_ROOT:-__PACK_ROOT__}\"; S=\"$R/hooks/scripts/track-telemetry.sh\"; [ -f \"$S\" ] || exit 0; cd \"$R/hooks\" && chmod +x \"$S\" && \"$S\"'",
