        "linux": "bash --noprofile --norc -c 'R=\"${CLAUDE_PLUGIN_ROOT:-__PACK_ROOT__}\"; S=\"$R/hooks/scripts/track-telemetry.sh\"; [ -f \"$S\" ] || exit 0; cd \"$R/hooks\" && chmod +x \"$S\" && \"$S\"'",
        "windows": "powershell -NoProfile -ExecutionPolicy Bypass -File \"__PACK_ROOT__\\hooks\\scripts\\track-telemetry.ps1\""
      },
      {
        "type": "command",
        "command": "bash --noprofile --norc -c 'R=\"${CLAUDE_PLUGIN_ROOT:-__PACK_ROOT__}\"; S=\"$R/hooks/scripts/skill-improve-detect.sh\"; [ -f \"$S\" ] || exit 0; chmod +x \"$S\" && \"$S\"'",
        "osx": "bash --noprofile --norc -c 'R=\"${CLAUDE_PLUGIN_ROOT:-__PACK_ROOT__}\"; S=\"$R/hooks/scripts/skill-improve-detect.sh\"; [ -f \"$S\" ] || exit 0; chmod +x \"$S\" && \"$S\"'",
        "linux": "bash --noprofile --norc -c 'R=\"${CLAUDE_PLUGIN_ROOT:-__PACK_ROOT__}\"; S=\"$R/hooks/scripts/skill-improve-detect.sh\"; [ -f \"$S\" ] || exit 0; chmod +x \"$S\" && \"$S\"'",
        "windows": "powershell -NoProfile -ExecutionPolicy Bypass -File \"__PACK_ROOT__\\hooks\\scripts\\skill-improve-detect.ps1\""
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "bash --noprofile --norc -c 'R=\"${CLAUDE_PLUGIN_ROOT:-__PACK_ROOT__}\"; S=\"$R/hooks/scripts/skill-improve-session-end.sh\"; [ -f \"$S\" ] || exit 0; chmod +x \"$S\" && \"$S\"'",
        "osx": "bash --noprofile --norc -c 'R=\"${CLAUDE_PLUGIN_ROOT:-__PACK_ROOT__}\"; S=\"$R/hooks/scripts/skill-improve-session-end.sh\"; [ -f \"$S\" ] || exit 0; chmod +x \"$S\" && \"$S\"'",
