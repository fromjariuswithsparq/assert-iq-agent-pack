{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QI Outcome Signal Payload",
  "type": "object",
  "required": ["run_id", "commit_sha", "maturity_tier"],
  "properties": {
    "run_id": { "type": "string" },
    "commit_sha": { "type": "string" },
    "branch": { "type": "string" },
    "pr_id": { "type": ["string", "null"] },
    "maturity_tier": { "enum": ["early", "mid", "higher"] },
    "signal_type": {
      "description": "Optional discriminator. When present and equal to 'hotspot.map_generated', the payload is a per-repo periodic registry signal and the 'hotspot' object is required instead of 'layers'.",
      "enum": ["pr.risk_assessed", "coverage.analysis", "release.confidence", "hotspot.map_generated"]
    },
    "hotspot": {
      "description": "Per-repo Hotspot Risk Registry signal emitted by generate-hotspot-map.",
      "type": "object",
      "properties": {
        "refresh_trigger": { "enum": ["sprint", "on_demand"] },
        "module_count": { "type": "integer" },
        "tier_counts": {
          "type": "object",
          "properties": {
            "critical": { "type": "integer" },
            "medium": { "type": "integer" },
            "low": { "type": "integer" },
            "watchlist": { "type": "integer" }
          }
        },
        "hri_basis_distribution": {
          "type": "object",
          "description": "Count of rows by which signals were GRADED (e.g. V+C+D, V+C, V_only).",
          "additionalProperties": { "type": "integer" }
        },
        "ungraded_signals": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["signal", "reason"],
            "properties": {
              "signal": { "enum": ["volatility", "complexity", "defect_density"] },
              "reason": { "type": "string" }
            }
          }
        },
        "registry_path": { "type": "string" },
        "registry_json_path": { "type": "string" },
        "volatility_lookback_days": { "type": "integer" },
        "defect_density_lookback_days": { "type": "integer" }
      }
    },
    "layers": {
      "type": "object",
      "required": ["change", "protection", "trust", "outcome", "decision"],
      "properties": {
        "change": {
          "type": "object",
          "properties": {
            "files_changed": { "type": "integer" },
            "services_touched": { "type": "array", "items": { "type": "string" } },
            "churn_lines": { "type": "integer" },
            "late_changes": { "type": "integer" }
          }
        },
        "protection": {
          "type": "object",
          "properties": {
            "tests_executed": { "type": "integer" },
            "coverage_pct": { "type": "number" },
            "traceability_pct": { "type": "number" }
          }
        },
        "trust": {
          "type": "object",
          "properties": {
            "flaky_count": { "type": "integer" },
            "blocked_count": { "type": "integer" },
            "env_uptime_pct": { "type": "number" }
          }
        },
        "outcome": {
          "type": "object",
          "properties": {
            "defects_open": { "type": "integer" },
            "escapes_30d": { "type": "integer" },
            "telemetry_alerts": { "type": "integer" }
          }
        },
        "decision": {
          "type": "object",
          "properties": {
            "release_confidence": { "enum": ["green", "amber", "red"] },
            "mitigation_required": { "type": "boolean" }
          }
        }
      }
    }
  }
}
